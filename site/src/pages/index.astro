---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ModuleCard from "@/components/ModuleCard.astro";
import ContactForm from "@/components/ContactForm.astro";
import { site, modules, ecosystem, pillars } from "@/data/site";
---

<BaseLayout>
  <section class="relative border-b border-hub-border">
    <div class="relative section-pad !pb-20 !pt-16 sm:!pt-24">
      <p class="text-genius-cyan text-xs font-semibold uppercase tracking-widest mb-4 font-mono">
        Tech holding · {site.region}
      </p>
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-semibold text-white leading-tight max-w-4xl">
        {site.heroLine}
      </h1>
      <p class="mt-6 text-lg text-hub-muted max-w-2xl leading-relaxed">
        {site.description}
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href="#moduli" class="btn-primary">Esplora i moduli</a>
        <a href={site.profileUrl} class="btn-outline">Chi sono</a>
      </div>
    </div>
  </section>

  <section class="section-pad border-b border-hub-border bg-hub-card/20">
    <p class="text-genius-violet text-xs font-semibold uppercase tracking-widest mb-3">Perché genius</p>
    <h2 class="font-display text-3xl text-white mb-10">Tre pilastri, un ecosistema</h2>
    <div class="grid md:grid-cols-3 gap-6">
      {pillars.map((pillar) => (
        <article class="card">
          <h3 class="font-semibold text-white mb-2">{pillar.title}</h3>
          <p class="text-sm text-hub-muted leading-relaxed">{pillar.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="moduli" class="section-pad border-b border-hub-border">
    <p class="text-genius-cyan text-xs font-semibold uppercase tracking-widest mb-3">Prodotti</p>
    <h2 class="font-display text-3xl text-white mb-4">Moduli software</h2>
    <p class="text-hub-muted max-w-2xl mb-10 leading-relaxed">
      Ogni modulo risolve un problema specifico. L'hub collega vetrina, applicazione e strumenti analitici
      senza duplicare backend.
    </p>
    <div class="grid md:grid-cols-2 gap-6">
      {modules.map((mod) => (
        <ModuleCard module={mod} />
      ))}
    </div>
  </section>

  <section class="section-pad border-b border-hub-border">
    <p class="text-genius-emerald text-xs font-semibold uppercase tracking-widest mb-3">Ecosistema</p>
    <h2 class="font-display text-3xl text-white mb-10">Altri domini collegati</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {ecosystem.map((item) => (
        <a href={item.url} class="card group hover:border-genius-cyan/50 transition" target="_blank" rel="noopener">
          <p class="font-semibold text-white group-hover:text-genius-cyan transition">{item.label}</p>
          <p class="mt-1 text-xs text-hub-muted">{item.hint}</p>
          <p class="mt-3 text-xs font-mono text-genius-violet/80 truncate">{item.url.replace("https://", "")}</p>
        </a>
      ))}
    </div>
  </section>

  <section id="contatto" class="section-pad">
    <div class="card max-w-2xl mx-auto">
      <h2 class="font-display text-2xl text-white mb-3 text-center">Parliamo del tuo progetto</h2>
      <p class="text-hub-muted text-sm leading-relaxed mb-8 text-center">
        Startup, CER, assicurazioni parametriche o modelli finanziari — invia una richiesta a
        <span class="text-genius-cyan">{site.contactEmail}</span>.
      </p>
      <ContactForm />
    </div>
  </section>
</BaseLayout>
