---
import { site } from "@/data/site";
---

<header class="sticky top-0 z-50 border-b border-hub-border/80 bg-hub/90 backdrop-blur-md">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-3 min-w-0">
      <span
        class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-gradient-to-br from-genius-cyan to-genius-violet text-xs font-bold text-hub font-mono"
        aria-hidden="true">GF</span>
      <span class="min-w-0">
        <span class="block font-semibold text-white truncate">{site.brand}</span>
        <span class="block text-xs text-hub-muted truncate hidden sm:block">{site.tagline}</span>
      </span>
    </a>
    <nav class="flex items-center gap-2 sm:gap-4 text-sm">
      <a href="#moduli" class="hidden sm:inline text-hub-muted hover:text-white">Moduli</a>
      <a href={site.profileUrl} class="hidden sm:inline text-hub-muted hover:text-white">Profilo</a>
      <a href="#contatto" class="btn-primary py-2 px-4 text-xs sm:text-sm">Contatti</a>
    </nav>
  </div>
</header>
